; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="galgame"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon3.png"

[audio]

default_bus_layout="res://default_bus_layout.tres"

[autoload]

EventBus="res://autoload/EventBus.gd"
DialogManager="res://autoload/DialogManager.gd"
AchievementManager="res://autoload/AchievementManager.gd"
SaveManager="res://autoload/SaveManager.gd"
TransitionManager="res://autoload/TransitionManager.gd"
AudioManager="res://autoload/AudioManager.gd"

[display]

window/size/viewport_width=1170
window/size/viewport_height=660
window/stretch/mode="canvas_items"

[rendering]

textures/vram_compression/import_etc2_astc=true
